{
  "name": "ozanilbey",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --outDir build/client",
    "build:server": "vite build --ssr source/server.jsx --outDir build/server --target esnext",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "postinstall": "npm run build",
    "start": "npm run start:development",
    "start:development": "vite --mode development",
    "start:production": "NODE_ENV=production node build/server/server.js"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "express": "^5.1.0",
    "markdown-to-jsx": "^9.7.9",
    "nodemailer": "^7.0.6",
    "prop-types": "^15.8.1",
    "react": "^19.0.0",
    "react-calendly": "^4.4.0",
    "react-dom": "^19.0.0",
    "react-gtm-module": "^2.0.11",
    "react-router-dom": "^6.22.0",
    "react-syntax-highlighter": "^16.1.1"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.24.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "eslint": "^9.20.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "sass": "^1.70.0",
    "vite": "^6.1.0"
  }
}
